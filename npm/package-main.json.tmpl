{
    "name": "@ondeinference/cli",
    "version": "${release_version}",
    "keywords": [
        "onde",
        "cli",
        "onde-cli",
        "inference",
        "llm",
        "ai",
        "on-device",
        "developer",
        "tools"
    ],
    "bin": {
        "onde": "lib/index.js"
    },
    "files": ["lib", "README.md"],
    "description": "A CLI for managing your Onde Inference account and models.",
    "license": "MIT OR Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ondeinference/onde-cli.git"
    },
    "scripts": {
        "typecheck": "tsc --noEmit",
        "build": "tsc",
        "dev": "npm run build && node lib/index.js"
    },
    "devDependencies": {
        "@types/node": "^18.15.11",
        "typescript": "^5.0.0"
    },
    "optionalDependencies": {
        "@ondeinference/cli-darwin-arm64": "${release_version}",
        "@ondeinference/cli-darwin-x64": "${release_version}",
        "@ondeinference/cli-linux-arm64": "${release_version}",
        "@ondeinference/cli-linux-x64": "${release_version}",
        "@ondeinference/cli-windows-arm64": "${release_version}",
        "@ondeinference/cli-windows-x64": "${release_version}"
    }
}
